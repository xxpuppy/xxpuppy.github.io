---
// 导航栏组件 - Pill Nav 风格
import PillNavBar from './react/PillNavBar';
import ThemeToggle from './react/ThemeToggle';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/archives', label: 'Archives' },
  { href: '/about', label: 'About' },
];

// 计算当前激活的导航项（支持前缀匹配）
const activeHref = navItems.find(
  (item) => item.href === currentPath || (item.href !== '/' && currentPath.startsWith(item.href))
)?.href || '/';
---

<header class="header" id="site-header">
  <div class="header-main">
    <PillNavBar
      logo="/avatar.jpg"
      logoAlt="xxpuppy"
      items={navItems}
      activeHref={activeHref}
      baseColor="var(--bg-header)"
      pillColor="var(--accent)"
      hoveredPillTextColor="var(--text-primary)"
      pillTextColor="var(--text-primary)"
      initialLoadAnimation={false}
      client:load
    />
    <div class="header-actions">
      <ThemeToggle client:load />
    </div>
  </div>
</header>

<script>
  (() => {
    const header = document.getElementById('site-header');
    if (!header) return;
    let lastScrollY = 0;
    let ticking = false;
    const THRESHOLD = 10;

    const onScroll = () => {
      const currentY = window.scrollY;
      if (currentY < THRESHOLD) {
        header.classList.remove('header--hidden');
        lastScrollY = currentY;
        return;
      }
      if (currentY - lastScrollY > THRESHOLD) {
        header.classList.add('header--hidden');
      } else if (lastScrollY - currentY > THRESHOLD) {
        header.classList.remove('header--hidden');
      }
      lastScrollY = currentY;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { onScroll(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 1px solid rgba(78, 78, 100, 0.15);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateY(0);
    opacity: 1;
  }

  .header--hidden {
    transform: translateY(-100%);
    opacity: 0;
  }
  
  .header-main {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 72px;
    padding: 0 24px;
    max-width: 968px;
    margin: 0 auto;
  }

  .header-actions {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>
