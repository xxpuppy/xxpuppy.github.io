---
// 导航栏组件
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/blog', label: 'Blog', icon: '📝' },
  { href: '/archives', label: 'Archives', icon: '📚' },
  { href: '/about', label: 'About', icon: '👤' },
];
---

<header class="header">
  <div class="header-main">
    <a href="/" class="logo">
      <img src="/avatar.jpg" alt="xxpuppy" class="avatar" />
      <span class="logo-text">xxpuppy</span>
    </a>
    
    <nav class="nav-desktop">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class:list={['nav-item', 'magical', 'btn', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    
    <button class="menu-toggle magical btn" id="menu-toggle" aria-label="Toggle menu">
      <span class="menu-icon"></span>
    </button>
  </div>
  
  <div class="nav-mobile" id="nav-mobile">
    <div class="nav-mobile-content">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class:list={['nav-item', 'magical', 'btn', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
        >
          <span class="nav-icon">{item.icon}</span>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: rgba(25, 25, 32, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(78, 78, 100, 0.3);
  }
  
  .header-main {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 80px;
    padding: 0 24px;
    max-width: 968px;
    margin: 0 auto;
  }
  
  .logo {
    position: absolute;
    left: 24px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #E8E8F6;
    font-size: 18px;
    font-weight: 600;
    text-decoration: none;
  }
  
  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(99, 97, 220, 0.5);
  }
  
  .logo-text {
    background: linear-gradient(135deg, #A29CD3, #E8BFAC);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .nav-desktop {
    display: flex;
    gap: 8px;
  }
  
  .nav-item {
    padding: 8px 20px;
    font-size: 14px;
    color: #B3B3C1;
    transition: all 0.3s ease;
    border-radius: 9999px;
  }
  
  .nav-item:hover {
    color: #E8E8F6;
  }
  
  .nav-item.active {
    color: #E8E8F6;
    background-color: #6361DC;
  }
  
  .menu-toggle {
    display: none;
    position: absolute;
    right: 24px;
    width: 40px;
    height: 40px;
    padding: 0;
    cursor: pointer;
  }
  
  .menu-icon {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #E8E8F6;
    position: relative;
    transition: all 0.3s ease;
  }
  
  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: #E8E8F6;
    transition: all 0.3s ease;
  }
  
  .menu-icon::before {
    top: -6px;
  }
  
  .menu-icon::after {
    top: 6px;
  }
  
  .nav-mobile {
    display: none;
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(14, 14, 19, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 99;
  }
  
  .nav-mobile.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .nav-mobile-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
  }
  
  .nav-mobile-content .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    font-size: 18px;
    justify-content: center;
  }
  
  .nav-icon {
    font-size: 20px;
  }
  
  @media screen and (max-width: 768px) {
    .nav-desktop {
      display: none;
    }
    
    .menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  // 移动端菜单切换
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const navMobile = document.getElementById('nav-mobile');
    const menuIcon = menuToggle?.querySelector('.menu-icon');
    
    if (menuToggle && navMobile) {
      menuToggle.addEventListener('click', () => {
        navMobile.classList.toggle('active');
        menuIcon?.classList.toggle('active');
      });
      
      // 点击导航项后关闭菜单
      const navItems = navMobile.querySelectorAll('.nav-item');
      navItems.forEach((item) => {
        item.addEventListener('click', () => {
          navMobile.classList.remove('active');
          menuIcon?.classList.remove('active');
        });
      });
    }
  });
</script>
