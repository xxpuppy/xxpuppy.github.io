---
// 博客文章卡片组件
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, categories, description } = post.data;

// 格式化日期
const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

// 获取分类颜色
function getCategoryColor(category: string): string {
  const colors: Record<string, string> = {
    '核心漏洞': '#FF6B6B',
    '特定场景渗透': '#4ECDC4',
    '特殊漏洞': '#FFE66D',
    'web服务器-中间件漏洞总结': '#95E1D3',
  };
  return colors[category] || '#6361DC';
}
---

<article class="blog-card magical">
  <a href={`/blog/${post.id}`} class="card-link">
    <div class="card-header">
      <div class="card-categories">
        {categories.map((category) => (
          <span 
            class="category-tag"
            style={`background-color: ${getCategoryColor(category)}20; color: ${getCategoryColor(category)}`}
          >
            {category}
          </span>
        ))}
      </div>
      <time class="card-date" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </div>
    
    <h3 class="card-title">{title}</h3>
    
    {description && (
      <p class="card-description">{description}</p>
    )}
    
    <div class="card-footer">
      <span class="read-more">
        阅读全文
        <span class="arrow">→</span>
      </span>
    </div>
  </a>
</article>

<style>
  .blog-card {
    background-color: var(--bg-card);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    border: 1px solid var(--border-light);
  }
  
  .blog-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0px 4px 12px 0px rgba(10, 10, 14, 0.3);
  }
  
  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 24px;
    text-decoration: none;
    color: inherit;
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
    gap: 12px;
  }
  
  .card-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  
  .category-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
  }
  
  .card-date {
    color: var(--text-tertiary);
    font-size: 12px;
    flex-shrink: 0;
  }
  
  .card-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .card-description {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .card-footer {
    margin-top: auto;
  }
  
  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    font-size: 14px;
    font-weight: 500;
    transition: gap 0.3s ease;
  }
  
  .blog-card:hover .read-more {
    gap: 12px;
  }
  
  .arrow {
    transition: transform 0.3s ease;
  }
  
  .blog-card:hover .arrow {
    transform: translateX(4px);
  }
</style>
