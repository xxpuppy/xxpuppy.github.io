---
// 左侧笔记目录导航组件
interface Props {
  currentPostId: string;
}

const { currentPostId } = Astro.props;

// 获取所有文章并按分类分组
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 按分类分组
const postsByCategory = allPosts.reduce((acc, post) => {
  post.data.categories.forEach((category) => {
    if (!acc[category]) {
      acc[category] = [];
    }
    acc[category].push(post);
  });
  return acc;
}, {} as Record<string, typeof allPosts>);

// 分类排序
const sortedCategories = Object.keys(postsByCategory).sort();
---

<aside class="note-sidebar" id="note-sidebar">
  <div class="sidebar-header">
    <h3>笔记目录</h3>
    <button class="sidebar-toggle" id="sidebar-toggle" title="收起目录">
      <span class="toggle-icon"></span>
    </button>
  </div>
  
  <nav class="sidebar-content" id="sidebar-content">
    {sortedCategories.map((category) => (
      <div class="category-group">
        <button class="category-header" data-category={category}>
          <span class="category-name">{category}</span>
          <span class="category-count">{postsByCategory[category].length}</span>
          <span class="category-arrow">›</span>
        </button>
        <ul class="category-posts">
          {postsByCategory[category].map((post) => (
            <li class:list={['post-item', { 'is-current': post.id === currentPostId }]}>
              <a href={`/blog/${post.id}`} class="post-link">
                <span class="post-title">{post.data.title}</span>
                <time class="post-date">
                  {post.data.date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .note-sidebar {
    position: fixed;
    left: 20px;
    top: 120px;
    width: 320px;
    max-height: calc(100vh - 200px);
    background-color: #141419;
    border-radius: 12px;
    border: 1px solid rgba(78, 78, 100, 0.3);
    z-index: 10;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: width 0.3s ease;
  }
  
  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(78, 78, 100, 0.3);
    flex-shrink: 0;
  }
  
  .sidebar-header h3 {
    font-size: 17px;
    font-weight: 600;
    color: #E8E8F6;
    margin: 0;
    background: linear-gradient(135deg, #A29CD3, #E8BFAC);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .sidebar-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }
  
  .sidebar-toggle:hover {
    opacity: 1;
  }
  
  .toggle-icon {
    display: block;
    width: 16px;
    height: 16px;
    position: relative;
  }
  
  .toggle-icon::before,
  .toggle-icon::after {
    content: '';
    position: absolute;
    background-color: #B3B3C1;
    transition: transform 0.3s ease;
  }
  
  .toggle-icon::before {
    width: 100%;
    height: 2px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }
  
  .toggle-icon::after {
    width: 2px;
    height: 100%;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }
  
  .sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 12px 0;
  }
  
  .sidebar-content::-webkit-scrollbar {
    width: 4px;
  }
  
  .sidebar-content::-webkit-scrollbar-track {
    background: transparent;
  }
  
  .sidebar-content::-webkit-scrollbar-thumb {
    background-color: rgba(78, 78, 100, 0.5);
    border-radius: 2px;
  }
  
  .category-group {
    margin-bottom: 4px;
  }
  
  .category-header {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 12px 20px;
    background: none;
    border: none;
    cursor: pointer;
    color: #B3B3C1;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    text-align: left;
  }
  
  .category-header:hover {
    color: #E8E8F6;
    background-color: rgba(99, 97, 220, 0.05);
  }
  
  .category-name {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  
  .category-count {
    font-size: 12px;
    color: #62616F;
    background-color: rgba(78, 78, 100, 0.3);
    padding: 2px 8px;
    border-radius: 10px;
    margin-left: 8px;
    min-width: 20px;
    text-align: center;
  }
  
  .category-arrow {
    font-size: 16px;
    margin-left: 8px;
    transition: transform 0.3s ease;
    color: #62616F;
  }
  
  .category-group.expanded .category-arrow {
    transform: rotate(90deg);
  }
  
  .category-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  
  .category-group.expanded .category-posts {
    max-height: 1000px;
  }
  
  .post-item {
    border-left: 2px solid transparent;
    margin-left: 20px;
    transition: all 0.3s ease;
  }
  
  .post-item:hover {
    border-left-color: rgba(99, 97, 220, 0.3);
  }
  
  .post-item.is-current {
    border-left-color: #6361DC;
  }
  
  .post-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    text-decoration: none;
    color: #62616F;
    font-size: 13px;
    transition: all 0.3s ease;
    gap: 8px;
  }
  
  .post-link:hover {
    color: #E8E8F6;
    background-color: rgba(99, 97, 220, 0.05);
  }
  
  .post-item.is-current .post-link {
    color: #E8E8F6;
    background-color: rgba(99, 97, 220, 0.1);
  }
  
  .post-title {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.5;
  }
  
  .post-date {
    font-size: 12px;
    color: #62616F;
    flex-shrink: 0;
  }
  
  /* 移动端隐藏 */
  @media screen and (max-width: 1400px) {
    .note-sidebar {
      display: none;
    }
  }
</style>

<script>
  // 侧边栏交互
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('note-sidebar');
    const sidebarContent = document.getElementById('sidebar-content');
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const categoryHeaders = document.querySelectorAll('.category-header');
    
    // 切换整个侧边栏
    if (sidebarToggle && sidebar) {
      sidebarToggle.addEventListener('click', () => {
        sidebar.classList.toggle('collapsed');
        if (sidebar.classList.contains('collapsed')) {
          sidebar.style.width = '48px';
          sidebarContent!.style.display = 'none';
        } else {
          sidebar.style.width = '320px';
          sidebarContent!.style.display = 'block';
        }
      });
    }
    
    // 切换分类展开/折叠
    categoryHeaders.forEach((header) => {
      header.addEventListener('click', () => {
        const group = header.closest('.category-group');
        if (group) {
          group.classList.toggle('expanded');
        }
      });
    });
    
    // 自动展开当前文章所在的分类
    const currentPost = document.querySelector('.post-item.is-current');
    if (currentPost) {
      const group = currentPost.closest('.category-group');
      if (group) {
        group.classList.add('expanded');
        // 滚动到可见位置
        setTimeout(() => {
          currentPost.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 300);
      }
    } else {
      // 如果没有当前文章，默认展开第一个分类
      const firstGroup = document.querySelector('.category-group');
      if (firstGroup) {
        firstGroup.classList.add('expanded');
      }
    }
  });
</script>
