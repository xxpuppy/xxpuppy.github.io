---
// 博客列表页面
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

// 获取所有文章
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 获取所有分类
const categories = [...new Set(posts.flatMap((post) => post.data.categories))];

// 获取所有标签
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
---

<BaseLayout title="博客">
  <section class="blog-page">
    <div class="container">
      <div class="blog-header">
        <h1 class="blog-title">技术博客</h1>
        <p class="blog-desc">
          分享网络安全技术、渗透测试经验、漏洞分析等内容
        </p>
      </div>
      
      <!-- 筛选器 -->
      <div class="filters">
        <div class="filter-group">
          <h3 class="filter-title">分类筛选</h3>
          <div class="filter-tags">
            <button class="filter-tag active" data-filter="all">
              全部
            </button>
            {categories.map((category) => (
              <button class="filter-tag" data-filter={category}>
                {category}
              </button>
            ))}
          </div>
        </div>
        
        {tags.length > 0 && (
          <div class="filter-group">
            <h3 class="filter-title">标签筛选</h3>
            <div class="filter-tags">
              {tags.map((tag) => (
                <button class="filter-tag" data-filter={tag} data-type="tag">
                  #{tag}
                </button>
              ))}
            </div>
          </div>
        )}
      </div>
      
      <!-- 文章列表 -->
      <div class="posts-grid" id="posts-grid">
        {posts.map((post) => (
          <div 
            class="post-item"
            data-categories={post.data.categories.join(',')}
            data-tags={post.data.tags.join(',')}
          >
            <BlogCard post={post} />
          </div>
        ))}
      </div>
      
      <!-- 空状态 -->
      <div class="empty-state" id="empty-state" style="display: none;">
        <div class="empty-icon">📝</div>
        <h3 class="empty-title">暂无文章</h3>
        <p class="empty-desc">该分类下暂无文章，请选择其他分类查看</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-page {
    padding: 40px 0 80px;
  }
  
  .blog-header {
    text-align: center;
    margin-bottom: 48px;
  }
  
  .blog-title {
    font-size: 36px;
    font-weight: 700;
    background: linear-gradient(135deg, #A29CD3, #E8BFAC);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }
  
  .blog-desc {
    color: #B3B3C1;
    font-size: 16px;
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* 筛选器 */
  .filters {
    background-color: #141419;
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 40px;
    border: 1px solid rgba(78, 78, 100, 0.3);
  }
  
  .filter-group {
    margin-bottom: 20px;
  }
  
  .filter-group:last-child {
    margin-bottom: 0;
  }
  
  .filter-title {
    font-size: 14px;
    color: #62616F;
    margin-bottom: 12px;
    font-weight: 500;
  }
  
  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  
  .filter-tag {
    padding: 8px 16px;
    border-radius: 20px;
    background-color: #1F1F26;
    color: #B3B3C1;
    border: none;
    cursor: pointer;
    font-size: 13px;
    transition: all 0.3s ease;
  }
  
  .filter-tag:hover {
    background-color: #2A2A35;
    color: #E8E8F6;
  }
  
  .filter-tag.active {
    background-color: #6361DC;
    color: #ffffff;
  }
  
  /* 文章网格 */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }
  
  .post-item {
    transition: all 0.3s ease;
  }
  
  .post-item.hidden {
    display: none;
  }
  
  /* 空状态 */
  .empty-state {
    text-align: center;
    padding: 80px 20px;
  }
  
  .empty-icon {
    font-size: 64px;
    margin-bottom: 24px;
  }
  
  .empty-title {
    font-size: 24px;
    color: #E8E8F6;
    margin-bottom: 12px;
  }
  
  .empty-desc {
    color: #62616F;
    font-size: 16px;
  }
  
  @media screen and (max-width: 768px) {
    .blog-title {
      font-size: 28px;
    }
    
    .posts-grid {
      grid-template-columns: 1fr;
    }
    
    .filters {
      padding: 16px;
    }
  }
</style>

<script>
  // 筛选功能
  document.addEventListener('DOMContentLoaded', () => {
    const filterTags = document.querySelectorAll('.filter-tag');
    const postItems = document.querySelectorAll('.post-item');
    const emptyState = document.getElementById('empty-state');
    
    let activeCategory = 'all';
    let activeTag = '';
    
    filterTags.forEach((tag) => {
      tag.addEventListener('click', () => {
        const filter = tag.getAttribute('data-filter');
        const type = tag.getAttribute('data-type');
        
        // 更新激活状态
        if (type === 'tag') {
          // 标签筛选
          if (activeTag === filter) {
            activeTag = '';
            tag.classList.remove('active');
          } else {
            // 移除其他标签的激活状态
            document.querySelectorAll('.filter-tag[data-type="tag"]').forEach((t) => {
              t.classList.remove('active');
            });
            activeTag = filter || '';
            tag.classList.add('active');
          }
        } else {
          // 分类筛选
          document.querySelectorAll('.filter-tag:not([data-type="tag"])').forEach((t) => {
            t.classList.remove('active');
          });
          activeCategory = filter || 'all';
          tag.classList.add('active');
        }
        
        // 应用筛选
        let visibleCount = 0;
        
        postItems.forEach((item) => {
          const categories = item.getAttribute('data-categories') || '';
          const tags = item.getAttribute('data-tags') || '';
          
          const categoryMatch = activeCategory === 'all' || categories.includes(activeCategory);
          const tagMatch = !activeTag || tags.includes(activeTag);
          
          if (categoryMatch && tagMatch) {
            item.classList.remove('hidden');
            visibleCount++;
          } else {
            item.classList.add('hidden');
          }
        });
        
        // 显示/隐藏空状态
        if (emptyState) {
          emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      });
    });
  });
</script>
