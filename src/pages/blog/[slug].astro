---
// 文章详情页面
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, categories, tags, description } = post.data;
const { Content, headings } = await render(post);

// 格式化日期
const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// 获取相关文章
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.categories.some((c) => categories.includes(c)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <div class="container">
      <!-- 文章头部 -->
      <header class="post-header">
        <div class="post-meta">
          <div class="post-categories">
            {categories.map((category) => (
              <a href={`/blog?category=${category}`} class="category-tag">
                {category}
              </a>
            ))}
          </div>
          <time class="post-date" datetime={date.toISOString()}>
            {formattedDate}
          </time>
        </div>
        
        <h1 class="post-title">{title}</h1>
        
        {description && (
          <p class="post-description">{description}</p>
        )}
        
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <a href={`/blog?tag=${tag}`} class="tag">
                #{tag}
              </a>
            ))}
          </div>
        )}
      </header>
      
      <!-- 文章目录 -->
      {headings.length > 0 && (
        <aside class="toc">
          <div class="toc-header">
            <h3>目录</h3>
            <button class="toc-toggle" id="toc-toggle">
              <span class="toc-icon"></span>
            </button>
          </div>
          <nav class="toc-content" id="toc-content">
            <ul>
              {headings.map((heading) => (
                <li class:list={['toc-item', `toc-level-${heading.depth}`]}>
                  <a href={`#${heading.slug}`}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
      
      <!-- 文章内容 -->
      <div class="post-content">
        <Content />
      </div>
      
      <!-- 文章底部 -->
      <footer class="post-footer">
        <!-- 分享 -->
        <div class="post-share">
          <span class="share-label">分享文章：</span>
          <div class="share-buttons">
            <button class="share-btn" data-platform="twitter" title="分享到 Twitter">
              🐦
            </button>
            <button class="share-btn" data-platform="weibo" title="分享到微博">
              📢
            </button>
            <button class="share-btn" data-platform="copy" title="复制链接">
              📋
            </button>
          </div>
        </div>
        
        <!-- 相关文章 -->
        {relatedPosts.length > 0 && (
          <div class="related-posts">
            <h3 class="related-title">相关文章</h3>
            <div class="related-grid">
              {relatedPosts.map((related) => (
                <a href={`/blog/${related.id}`} class="related-item">
                  <div class="related-categories">
                    {related.data.categories.map((cat) => (
                      <span class="related-category">{cat}</span>
                    ))}
                  </div>
                  <h4 class="related-name">{related.data.title}</h4>
                  <time class="related-date">
                    {related.data.date.toLocaleDateString('zh-CN')}
                  </time>
                </a>
              ))}
            </div>
          </div>
        )}
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: 40px 0 80px;
  }
  
  /* 文章头部 */
  .post-header {
    margin-bottom: 48px;
    text-align: center;
  }
  
  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin-bottom: 24px;
  }
  
  .post-categories {
    display: flex;
    gap: 8px;
  }
  
  .category-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 4px;
    background-color: rgba(99, 97, 220, 0.1);
    color: #6361DC;
    font-size: 13px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .category-tag:hover {
    background-color: rgba(99, 97, 220, 0.2);
  }
  
  .post-date {
    color: #62616F;
    font-size: 14px;
  }
  
  .post-title {
    font-size: 36px;
    font-weight: 700;
    color: #E8E8F6;
    margin-bottom: 16px;
    line-height: 1.3;
  }
  
  .post-description {
    color: #B3B3C1;
    font-size: 18px;
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto 24px;
  }
  
  .post-tags {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  
  .tag {
    color: #62616F;
    font-size: 14px;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .tag:hover {
    color: #E8E8F6;
  }
  
  /* 文章目录 */
  .toc {
    position: fixed;
    right: 20px;
    top: 120px;
    width: 250px;
    max-height: calc(100vh - 200px);
    overflow-y: auto;
    background-color: #141419;
    border-radius: 8px;
    padding: 20px;
    border: 1px solid rgba(78, 78, 100, 0.3);
    z-index: 10;
  }
  
  .toc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  
  .toc-header h3 {
    font-size: 16px;
    color: #E8E8F6;
    margin: 0;
  }
  
  .toc-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  
  .toc-icon {
    display: block;
    width: 16px;
    height: 2px;
    background-color: #B3B3C1;
    position: relative;
  }
  
  .toc-icon::before,
  .toc-icon::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: #B3B3C1;
  }
  
  .toc-icon::before {
    top: -6px;
  }
  
  .toc-icon::after {
    top: 6px;
  }
  
  .toc-content ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .toc-item {
    margin-bottom: 8px;
  }
  
  .toc-item a {
    color: #62616F;
    font-size: 13px;
    text-decoration: none;
    transition: color 0.3s ease;
    display: block;
    padding: 4px 0;
  }
  
  .toc-item a:hover {
    color: #E8E8F6;
  }
  
  .toc-level-2 {
    padding-left: 16px;
  }
  
  .toc-level-3 {
    padding-left: 32px;
  }
  
  .toc-level-4 {
    padding-left: 48px;
  }
  
  /* 文章内容 */
  .post-content {
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }
  
  .post-content :global(h2) {
    font-size: 28px;
    color: #E8E8F6;
    margin-top: 48px;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 2px solid rgba(99, 97, 220, 0.3);
  }
  
  .post-content :global(h3) {
    font-size: 22px;
    color: #E8E8F6;
    margin-top: 36px;
    margin-bottom: 16px;
  }
  
  .post-content :global(h4) {
    font-size: 18px;
    color: #E8E8F6;
    margin-top: 24px;
    margin-bottom: 12px;
  }
  
  .post-content :global(p) {
    color: #B3B3C1;
    margin-bottom: 16px;
  }
  
  .post-content :global(a) {
    color: #6361DC;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }
  
  .post-content :global(a:hover) {
    border-bottom-color: #6361DC;
  }
  
  .post-content :global(ul),
  .post-content :global(ol) {
    color: #B3B3C1;
    margin-bottom: 16px;
    padding-left: 24px;
  }
  
  .post-content :global(li) {
    margin-bottom: 8px;
  }
  
  .post-content :global(blockquote) {
    border-left: 4px solid #6361DC;
    padding: 16px 20px;
    margin: 24px 0;
    background-color: rgba(99, 97, 220, 0.05);
    border-radius: 0 8px 8px 0;
  }
  
  .post-content :global(blockquote p) {
    color: #E8E8F6;
    margin: 0;
  }
  
  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 24px 0;
  }
  
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
  }
  
  .post-content :global(th),
  .post-content :global(td) {
    padding: 12px 16px;
    border: 1px solid rgba(78, 78, 100, 0.3);
    text-align: left;
  }
  
  .post-content :global(th) {
    background-color: #141419;
    color: #E8E8F6;
    font-weight: 600;
  }
  
  .post-content :global(td) {
    color: #B3B3C1;
  }
  
  /* 文章底部 */
  .post-footer {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid rgba(78, 78, 100, 0.3);
  }
  
  .post-share {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 48px;
  }
  
  .share-label {
    color: #62616F;
    font-size: 14px;
  }
  
  .share-buttons {
    display: flex;
    gap: 12px;
  }
  
  .share-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #1F1F26;
    border: none;
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  
  .share-btn:hover {
    background-color: #6361DC;
    transform: translateY(-2px);
  }
  
  .related-posts {
    margin-top: 48px;
  }
  
  .related-title {
    font-size: 24px;
    color: #E8E8F6;
    margin-bottom: 24px;
    text-align: center;
  }
  
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }
  
  .related-item {
    display: block;
    padding: 20px;
    background-color: #141419;
    border-radius: 8px;
    border: 1px solid rgba(78, 78, 100, 0.3);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .related-item:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 97, 220, 0.5);
  }
  
  .related-categories {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }
  
  .related-category {
    font-size: 12px;
    color: #6361DC;
    background-color: rgba(99, 97, 220, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
  }
  
  .related-name {
    font-size: 16px;
    color: #E8E8F6;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  
  .related-date {
    font-size: 12px;
    color: #62616F;
  }
  
  @media screen and (max-width: 1200px) {
    .toc {
      display: none;
    }
  }
  
  @media screen and (max-width: 768px) {
    .post-title {
      font-size: 28px;
    }
    
    .post-meta {
      flex-direction: column;
      gap: 12px;
    }
    
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // 分享功能
  document.addEventListener('DOMContentLoaded', () => {
    const shareButtons = document.querySelectorAll('.share-btn');
    
    shareButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const platform = btn.getAttribute('data-platform');
        const url = window.location.href;
        const title = document.title;
        
        switch (platform) {
          case 'twitter':
            window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`);
            break;
          case 'weibo':
            window.open(`https://service.weibo.com/share/share.php?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`);
            break;
          case 'copy':
            navigator.clipboard.writeText(url).then(() => {
              alert('链接已复制到剪贴板');
            });
            break;
        }
      });
    });
    
    // 目录切换
    const tocToggle = document.getElementById('toc-toggle');
    const tocContent = document.getElementById('toc-content');
    
    if (tocToggle && tocContent) {
      tocToggle.addEventListener('click', () => {
        tocContent.classList.toggle('collapsed');
      });
    }
  });
</script>
