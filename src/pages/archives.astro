---
// 归档页面
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取所有文章
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 按年份分组
const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

// 按分类分组
const postsByCategory = posts.reduce((acc, post) => {
  post.data.categories.forEach((category) => {
    if (!acc[category]) {
      acc[category] = [];
    }
    acc[category].push(post);
  });
  return acc;
}, {} as Record<string, typeof posts>);

// 统计信息
const totalPosts = posts.length;
const totalCategories = Object.keys(postsByCategory).length;
const totalTags = [...new Set(posts.flatMap((post) => post.data.tags))].length;
---

<BaseLayout title="归档">
  <section class="archives-page">
    <div class="container">
      <div class="archives-header">
        <h1 class="archives-title">文章归档</h1>
        <p class="archives-desc">
          共 {totalPosts} 篇文章，{totalCategories} 个分类，{totalTags} 个标签
        </p>
      </div>
      
      <!-- 统计卡片 -->
      <div class="stats-grid">
        <div class="stat-card magical">
          <div class="stat-icon">📝</div>
          <div class="stat-number">{totalPosts}</div>
          <div class="stat-label">文章总数</div>
        </div>
        <div class="stat-card magical">
          <div class="stat-icon">📁</div>
          <div class="stat-number">{totalCategories}</div>
          <div class="stat-label">分类数量</div>
        </div>
        <div class="stat-card magical">
          <div class="stat-icon">🏷️</div>
          <div class="stat-number">{totalTags}</div>
          <div class="stat-label">标签数量</div>
        </div>
      </div>
      
      <!-- 时间线归档 -->
      <div class="timeline-section">
        <h2 class="section-title">按时间归档</h2>
        <div class="timeline">
          {Object.entries(postsByYear).map(([year, yearPosts]) => (
            <div class="timeline-year">
              <div class="year-header">
                <span class="year-badge">{year}</span>
                <span class="year-count">{yearPosts.length} 篇</span>
              </div>
              <div class="year-posts">
                {yearPosts.map((post) => (
                  <a href={`/blog/${post.id}`} class="timeline-post">
                    <div class="post-date">
                      {post.data.date.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                    </div>
                    <div class="post-info">
                      <h3 class="post-title">{post.data.title}</h3>
                      <div class="post-categories">
                        {post.data.categories.map((cat) => (
                          <span class="post-category">{cat}</span>
                        ))}
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- 分类归档 -->
      <div class="category-section">
        <h2 class="section-title">按分类归档</h2>
        <div class="category-grid">
          {Object.entries(postsByCategory).map(([category, categoryPosts]) => (
            <div class="category-card magical">
              <div class="category-header">
                <h3 class="category-name">{category}</h3>
                <span class="category-count">{categoryPosts.length} 篇</span>
              </div>
              <div class="category-posts">
                {categoryPosts.slice(0, 5).map((post) => (
                  <a href={`/blog/${post.id}`} class="category-post">
                    <span class="post-date-small">
                      {post.data.date.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                    </span>
                    <span class="post-name">{post.data.title}</span>
                  </a>
                ))}
                {categoryPosts.length > 5 && (
                  <a href={`/blog?category=${category}`} class="view-more">
                    查看全部 {categoryPosts.length} 篇 →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .archives-page {
    padding: 40px 0 80px;
  }
  
  .archives-header {
    text-align: center;
    margin-bottom: 48px;
  }
  
  .archives-title {
    font-size: 36px;
    font-weight: 700;
    background: linear-gradient(135deg, #A29CD3, #E8BFAC);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }
  
  .archives-desc {
    color: #B3B3C1;
    font-size: 16px;
  }
  
  /* 统计卡片 */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 64px;
  }
  
  .stat-card {
    background-color: #141419;
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    border: 1px solid rgba(78, 78, 100, 0.3);
  }
  
  .stat-icon {
    font-size: 40px;
    margin-bottom: 16px;
  }
  
  .stat-number {
    font-size: 48px;
    font-weight: 700;
    color: #E8E8F6;
    margin-bottom: 8px;
  }
  
  .stat-label {
    color: #62616F;
    font-size: 14px;
  }
  
  /* 时间线 */
  .timeline-section {
    margin-bottom: 64px;
  }
  
  .section-title {
    font-size: 28px;
    color: #E8E8F6;
    margin-bottom: 32px;
    text-align: center;
  }
  
  .timeline {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .timeline-year {
    margin-bottom: 48px;
  }
  
  .year-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  
  .year-badge {
    display: inline-block;
    padding: 8px 20px;
    background: linear-gradient(135deg, #A29CD3, #E8BFAC);
    color: #0E0E13;
    font-size: 18px;
    font-weight: 700;
    border-radius: 20px;
  }
  
  .year-count {
    color: #62616F;
    font-size: 14px;
  }
  
  .year-posts {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-left: 24px;
    border-left: 2px solid rgba(99, 97, 220, 0.3);
  }
  
  .timeline-post {
    display: flex;
    gap: 16px;
    padding: 16px 20px;
    background-color: #141419;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 1px solid rgba(78, 78, 100, 0.3);
  }
  
  .timeline-post:hover {
    transform: translateX(8px);
    border-color: rgba(99, 97, 220, 0.5);
  }
  
  .post-date {
    color: #62616F;
    font-size: 14px;
    flex-shrink: 0;
    min-width: 60px;
  }
  
  .post-info {
    flex: 1;
  }
  
  .post-title {
    font-size: 16px;
    color: #E8E8F6;
    margin-bottom: 8px;
    font-weight: 500;
  }
  
  .post-categories {
    display: flex;
    gap: 8px;
  }
  
  .post-category {
    font-size: 12px;
    color: #6361DC;
    background-color: rgba(99, 97, 220, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
  }
  
  /* 分类归档 */
  .category-section {
    margin-bottom: 40px;
  }
  
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }
  
  .category-card {
    background-color: #141419;
    border-radius: 12px;
    padding: 24px;
    border: 1px solid rgba(78, 78, 100, 0.3);
  }
  
  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  
  .category-name {
    font-size: 20px;
    color: #E8E8F6;
  }
  
  .category-count {
    color: #6361DC;
    font-size: 14px;
    font-weight: 600;
  }
  
  .category-posts {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .category-post {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background-color: #1F1F26;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .category-post:hover {
    background-color: #2A2A35;
  }
  
  .post-date-small {
    color: #62616F;
    font-size: 12px;
    flex-shrink: 0;
  }
  
  .post-name {
    color: #B3B3C1;
    font-size: 14px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  
  .view-more {
    display: block;
    text-align: center;
    padding: 12px;
    color: #6361DC;
    font-size: 14px;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .view-more:hover {
    color: #A29CD3;
  }
  
  @media screen and (max-width: 768px) {
    .archives-title {
      font-size: 28px;
    }
    
    .stats-grid {
      grid-template-columns: 1fr;
    }
    
    .stat-number {
      font-size: 36px;
    }
    
    .timeline-post {
      flex-direction: column;
      gap: 8px;
    }
    
    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
