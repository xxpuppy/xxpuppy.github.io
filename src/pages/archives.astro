---
// 归档页面
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import MagicBentoArchives from '../components/react/MagicBentoArchives';
import AuroraBg from '../components/react/AuroraBg';

// 获取所有文章
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 按分类分组
const postsByCategory = posts.reduce((acc, post) => {
  post.data.categories.forEach((category) => {
    if (!acc[category]) {
      acc[category] = [];
    }
    acc[category].push(post);
  });
  return acc;
}, {} as Record<string, typeof posts>);

// 为 MagicBentoArchives 准备分类数据
const categoryCards = Object.entries(postsByCategory).map(([name, catPosts]) => ({
  name,
  count: catPosts.length,
  posts: catPosts.map((p) => ({
    title: p.data.title,
    date: p.data.date.toISOString(),
    slug: p.id
  }))
}));

const totalPosts = posts.length;
const totalCategories = Object.keys(postsByCategory).length;
---

<BaseLayout title="归档">
  <!-- Aurora 极光背景 -->
  <AuroraBg client:load />

  <section class="archives-page">
    <div class="container">
      <!-- 标题 -->
      <div class="archives-header">
        <h1 class="archives-title">文章归档</h1>
        <p class="archives-desc">共 {totalPosts} 篇文章，{totalCategories} 个分类</p>
      </div>

      <MagicBentoArchives
        categories={categoryCards}
        client:visible
      />
    </div>
  </section>
</BaseLayout>

<style>
  .archives-page {
    padding: 40px 0 80px;
  }

  .archives-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .archives-title {
    font-size: 36px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-gradient-start), var(--accent-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .archives-desc {
    color: var(--text-secondary);
    font-size: 16px;
    margin-top: 12px;
  }

  @media screen and (max-width: 768px) {
    .archives-title {
      font-size: 28px;
    }
  }
</style>
